# ── Claude API 配置 ─────────────────────────────────────────
# CLAUDE_MODE: "api" 使用 Anthropic 官方 API（需要 API Key）
#              "local" 使用 claude-max-api 本地代理（通过 Max Plan 订阅，无额外费用）
CLAUDE_MODE=local
CLAUDE_API_KEY=sk-ant-...
# claude-max-api 代理地址（仅 local 模式使用）
CLAUDE_BASE_URL=http://127.0.0.1:3456
CLAUDE_MODEL=claude-opus-4-6

# ── Reddit API 配置 ─────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=autodev-agent/0.1

# ── 数据库配置 ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autodev:autodev@localhost:5432/autodev
DATABASE_URL_SYNC=postgresql+psycopg2://autodev:autodev@localhost:5432/autodev

# ── Redis / Celery（可选，定时调度用）──────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── DALL-E 图标生成 ─────────────────────────────────────────
DALLE_API_KEY=sk-...

# ── Flutter SDK 路径 ────────────────────────────────────────
FLUTTER_SDK_PATH=/usr/local/flutter
FLUTTER_BIN=flutter
DART_BIN=dart

# ── HarmonyOS OHOS 开发环境（可选）──────────────────────────
# DevEco Studio SDK 路径
DEVECO_SDK_HOME=/Applications/DevEco-Studio.app/Contents
# OHOS SDK 路径
OHOS_SDK_HOME=/Users/你的用户名/Library/OpenHarmony/Sdk
# Flutter OHOS 分支路径（三端构建必需）
FLUTTER_OHOS_PATH=/usr/local/flutter-ohos

# ── 工作目录 ────────────────────────────────────────────────
WORKSPACE_DIR=workspace

# ── LangGraph 流水线配置 ────────────────────────────────────
# checkpoint 后端："memory"（开发）或 "sqlite"（生产）
PIPELINE_CHECKPOINT_BACKEND=sqlite
PIPELINE_CHECKPOINT_PATH=data/checkpoints.db
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_BACKOFF_BASE=2.0
PIPELINE_RETRY_BACKOFF_MAX=300.0

# ── 流水线调度参数 ──────────────────────────────────────────
PIPELINE_CRAWL_INTERVAL_HOURS=6
PIPELINE_MAX_CONCURRENT_BUILDS=2
PIPELINE_AUTO_APPROVE_THRESHOLD=0.75
PIPELINE_AUTO_REJECT_THRESHOLD=0.30

# ── App Store 发布配置 ──────────────────────────────────────
GOOGLE_PLAY_JSON_KEY_PATH=
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_KEY_PATH=

# ── 网络代理 ────────────────────────────────────────────────
NO_PROXY=127.0.0.1,localhost

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=INFO
