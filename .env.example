# ── Claude API 配置 ─────────────────────────────────────────
# 两种认证方式二选一，OAuth Token 优先级高于 API Key：
#   1) OAuth Token：Claude Pro/Max 订阅，运行 `claude setup-token` 获取，无额外按量费用
#   2) API Key：Anthropic 官方 API，按量计费
CLAUDE_OAUTH_TOKEN=
CLAUDE_API_KEY=sk-ant-...
# 可选：自建 API 网关地址，留空使用官方 Anthropic 端点
CLAUDE_BASE_URL=
CLAUDE_MODEL=claude-opus-4-8

# ── Reddit API 配置 ─────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=zerodev-agent/0.1

# ── 数据库配置 ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zerodev:zerodev@localhost:5432/zerodev
DATABASE_URL_SYNC=postgresql+psycopg2://zerodev:zerodev@localhost:5432/zerodev

# ── Redis / Celery（可选，定时调度用）──────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── DALL-E 图标生成 ─────────────────────────────────────────
DALLE_API_KEY=sk-...

# ── Flutter SDK 路径 ────────────────────────────────────────
FLUTTER_SDK_PATH=/usr/local/flutter
FLUTTER_BIN=flutter
DART_BIN=dart

# ── 构建平台 ────────────────────────────────────────────────
# 默认构建的目标平台，逗号分隔，可选：android,ios,ohos
# 例：仅鸿蒙 -> ohos；安卓+鸿蒙 -> android,ohos
TARGET_PLATFORMS=android

# ── HarmonyOS OHOS 开发环境（可选）──────────────────────────
# DevEco Studio SDK 路径
DEVECO_SDK_HOME=/Applications/DevEco-Studio.app/Contents
# OHOS SDK 路径
OHOS_SDK_HOME=/Users/你的用户名/Library/OpenHarmony/Sdk
# Flutter OHOS 分支路径（三端构建必需）
FLUTTER_OHOS_PATH=/usr/local/flutter-ohos

# ── 工作目录 ────────────────────────────────────────────────
WORKSPACE_DIR=workspace

# ── LangGraph 流水线配置 ────────────────────────────────────
# checkpoint 后端："memory"（开发）或 "sqlite"（生产）
PIPELINE_CHECKPOINT_BACKEND=sqlite
PIPELINE_CHECKPOINT_PATH=data/checkpoints.db
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_BACKOFF_BASE=2.0
PIPELINE_RETRY_BACKOFF_MAX=300.0

# ── 流水线调度参数 ──────────────────────────────────────────
PIPELINE_CRAWL_INTERVAL_HOURS=6
PIPELINE_MAX_CONCURRENT_BUILDS=2
PIPELINE_AUTO_APPROVE_THRESHOLD=0.75
PIPELINE_AUTO_REJECT_THRESHOLD=0.30

# ── App Store 发布配置 ──────────────────────────────────────
GOOGLE_PLAY_JSON_KEY_PATH=
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_KEY_PATH=

# ── 网络代理 ────────────────────────────────────────────────
NO_PROXY=127.0.0.1,localhost

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=INFO
